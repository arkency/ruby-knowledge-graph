<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Authorize</title>
  <style>
    body { font-family: system-ui, sans-serif; background: #f5f5f5; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; }
    .card { background: white; padding: 2rem; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); max-width: 400px; width: 100%; }
    h1 { font-size: 1.25rem; margin: 0 0 1rem; }
    label { display: block; margin-bottom: 0.5rem; font-weight: 500; }
    input[type="password"] { width: 100%; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px; font-size: 1rem; box-sizing: border-box; }
    button { margin-top: 1rem; width: 100%; padding: 0.75rem; background: #111; color: white; border: none; border-radius: 4px; font-size: 1rem; cursor: pointer; }
    button:hover { background: #333; }
    .error { color: #c00; margin-bottom: 1rem; }
  </style>
</head>
<body>
  <div class="card">
    <h1>Authorize MCP Access</h1>

    <% if @error.present? %>
      <p class="error"><%= @error %></p>
    <% end %>

    <%= form_tag(oauth_approve_path, method: :post) do %>
      <%= hidden_field_tag :client_id, @oauth_params[:client_id] %>
      <%= hidden_field_tag :redirect_uri, @oauth_params[:redirect_uri] %>
      <%= hidden_field_tag :state, @oauth_params[:state] %>
      <%= hidden_field_tag :code_challenge, @oauth_params[:code_challenge] %>
      <%= hidden_field_tag :code_challenge_method, @oauth_params[:code_challenge_method] %>
      <%= hidden_field_tag :scope, @oauth_params[:scope] %>
      <%= hidden_field_tag :response_type, @oauth_params[:response_type] %>

      <%= label_tag :password, "Admin Password" %>
      <%= password_field_tag :password, nil, autofocus: true %>

      <%= button_tag "Authorize" %>
    <% end %>
  </div>
</body>
</html>
